# Copy this file to .env and fill in only the providers you plan to use.
# Never commit real API keys.

# Required for real LLM calls. Keep false for dry runs/tests.
LLM_API_ENABLE=false

# Model provider API keys used by models.yaml.
OPENAI_API_KEY=
OPENROUTER_API_KEY=
SILICONFLOW_API_KEY=
DEEPSEEK_API_KEY=
ALIYUNCS_API_KEY=
MOONSHOT_API_KEY=
BYTEDANCE_API_KEY=

# Optional OpenRouter attribution headers.
OPENROUTER_SITE_URL=
OPENROUTER_SITE_NAME=

# Optional custom model configuration path.
# MODELS_YAML_PATH=models.yaml

# Optional retry and scheduling tuning, in seconds.
NETWORK_RETRY_DELAY=5
JSON_RETRY_DELAY=2.0
TASK_DISPATCH_DELAY=0.5
